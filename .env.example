# Sentinel — example environment configuration
#
# Copy to `.env` and fill in real values locally. NEVER commit `.env` or any
# real secret. This file holds documented placeholders only — no live values.
# Public data only; real bank data and real credentials never live here.

# --- LLM router (Anthropic + OpenAI behind a thin router) ---
# Keys are read from here only — never hardcoded or committed. With neither key
# set, the router runs in deterministic "offline" mode (no external call).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Provider: auto | anthropic | openai | offline  (auto picks by which key is set)
LLM_PROVIDER=auto
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# --- RAG / governance corpus (Phase 3) ---
# Where SR 26-2 / SR 11-7 / EU AI Act / NIST AI RMF / synthetic validation live.
GOVERNANCE_CORPUS_DIR=docs/governance
RAG_TOP_K=4

# --- Agent graph (Phase 3) ---
# Postgres DSN for metrics + immutable audit log (matches docker-compose).
POSTGRES_DSN=postgresql://sentinel:sentinel@localhost:5432/sentinel
# An amber score breach is escalated by the Monitor only at/above this PSI
# (red always escalates; a rising trend also escalates amber).
MATERIAL_AMBER_MIN=0.15

# --- Postgres (metrics + immutable audit log) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=
# Or supply a single URL instead of the parts above.
DATABASE_URL=postgresql://sentinel@localhost:5432/sentinel

# --- Kafka / Redpanda (local streaming) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTIONS_TOPIC=transactions
KAFKA_SCORED_TXNS_TOPIC=scored-txns
# Decision threshold for the fraud flag (matches the training report cut).
DECISION_THRESHOLD=0.85

# --- GCP Cloud Run (deploy target) ---
GOOGLE_CLOUD_PROJECT=
GCP_REGION=us-central1

# --- App ---
# Where the scoring service, backend, and frontend find each other locally.
BACKEND_BASE_URL=http://localhost:8000
